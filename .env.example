# Stripe Configuration
# Get your keys from https://dashboard.stripe.com/apikeys
# Use test keys (sk_test_...) for development, live keys (sk_live_...) for production.

# Required: Stripe secret key (server-side)
STRIPE_SECRET_KEY=sk_test_...

# Optional: Webhook signing secret for verifying Stripe webhook events
# Get this from https://dashboard.stripe.com/webhooks after creating an endpoint
STRIPE_WEBHOOK_SECRET=whsec_...

# Server port (default: 3000)
PORT=3000

# ---------------------------------------------------------------------------
# Email Service Provider (ESP) — configure ONE of these blocks.
# /api/subscribe auto-detects which one is set. Without any, signups only land
# in Vercel function logs.
# ---------------------------------------------------------------------------

# ConvertKit
# CONVERTKIT_API_KEY=
# CONVERTKIT_FORM_ID=

# Mailchimp (server prefix is the last segment of the dashboard URL, e.g. us21)
# MAILCHIMP_API_KEY=
# MAILCHIMP_LIST_ID=
# MAILCHIMP_SERVER_PREFIX=us21

# Beehiiv
# BEEHIIV_API_KEY=
# BEEHIIV_PUBLICATION_ID=

# Resend (Audiences API)
# RESEND_API_KEY=
# RESEND_AUDIENCE_ID=

# ---------------------------------------------------------------------------
# Social sign-in — set client IDs in config.js (client-side), not here.
# Apple Sign In requires a paid Apple Developer account.
# ---------------------------------------------------------------------------
